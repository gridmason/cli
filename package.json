{
  "name": "@gridmason/cli",
  "version": "0.0.1",
  "description": "The gridmason binary: the widget-author devkit (scaffold -> develop -> lint) and the publish path into a Gridmason Registry.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gridmason/cli.git"
  },
  "bugs": {
    "url": "https://github.com/gridmason/cli/issues"
  },
  "homepage": "https://github.com/gridmason/cli#readme",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "gridmason": "./dist/bin/gridmason.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./checks": {
      "types": "./dist/checks/index.d.ts",
      "import": "./dist/checks/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@gridmason/protocol": "0.0.3",
    "@gridmason/sdk": "^0.2.0",
    "ajv": "8.17.1",
    "chokidar": "4.0.3",
    "commander": "15.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "10.0.1",
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "happy-dom": "20.10.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "vue": "3.5.13"
  }
}
